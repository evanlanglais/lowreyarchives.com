# Supabase — required at build time (baked into SPA bundle) and runtime.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SECRET_KEY=

# S3 / Garage — runtime.
NUXT_S3_URL=https://garage-media-s3.lowreyarchives.com
NUXT_S3_KEY=
NUXT_S3_KEY_SECRET=
NUXT_S3_DMZ_BUCKET=fa-dmz
NUXT_S3_MEDIA_BUCKET=fa-media
NUXT_S3_REGION=garage

# nuxt-multi-cache invalidation API token.
NUXT_MULTI_CACHE_API_TOKEN=

# Cloudflare Tunnel token — from Zero Trust dashboard → Networks → Tunnels.
TUNNEL_TOKEN=
